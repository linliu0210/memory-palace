# Memory Palace — 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================================
# LLM Provider — AI 大模型接口（1F Foundation）
# ============================================================
# 支持 openai / anthropic / deepseek / local 等
MP_LLM__PROVIDER=openai
MP_LLM__MODEL_ID=gpt-4o-mini
MP_LLM__BASE_URL=https://api.openai.com/v1

# API Key — 对应你选择的 provider
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# DEEPSEEK_API_KEY=sk-your-key-here

# ============================================================
# Storage — 存储路径（2F Storage）
# ============================================================
# 运行时数据目录（core.json, recall.db, audit.jsonl 都在这里）
MP_STORAGE__BASE_DIR=./data

# Core Store 预算（条数上限）
MP_STORAGE__CORE_BUDGET=200

# ============================================================
# Curator — 搬运小人配置（4F Service）
# ============================================================
# 定时触发间隔（小时）
MP_CURATOR__TIMER_HOURS=24

# 会话累积触发阈值（攒多少次对话触发一次整理）
MP_CURATOR__SESSION_COUNT=20

# ============================================================
# Embedding — 向量嵌入 [v0.2]
# ============================================================
# MP_EMBEDDING__PROVIDER=openai
# MP_EMBEDDING__MODEL_ID=text-embedding-3-small
# MP_EMBEDDING__DIMENSION=1536

# ============================================================
# Debug
# ============================================================
# 日志级别: DEBUG / INFO / WARNING / ERROR
MP_LOG_LEVEL=INFO
